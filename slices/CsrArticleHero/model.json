{
  "id": "csr_article_hero",
  "type": "SharedSlice",
  "name": "CsrArticleHero",
  "description": "Dark immersive hero for CSR / event articles (matches Company Events).",
  "variations": [
    {
      "id": "default",
      "name": "Default",
      "docURL": "",
      "version": "initial",
      "description": "",
      "imageUrl": "",
      "primary": {
        "eyebrow": {
          "type": "Text",
          "config": { "label": "Eyebrow", "placeholder": "Company Events" }
        },
        "heading": {
          "type": "StructuredText",
          "config": {
            "label": "Title",
            "allowTargetBlank": false,
            "single": "heading1"
          }
        },
        "byline": {
          "type": "Text",
          "config": {
            "label": "Byline / attribution",
            "placeholder": "By Author Name, credentials (optional; editorials)"
          }
        },
        "subheading": {
          "type": "Text",
          "config": {
            "label": "Subtitle, date, or short dek",
            "placeholder": "Separate from byline — e.g. publication date"
          }
        },
        "banner_image_url": {
          "type": "Text",
          "config": {
            "label": "Background image URL",
            "placeholder": "https://... (optional)"
          }
        },
        "banner_image_alt": {
          "type": "Text",
          "config": { "label": "Image alt", "placeholder": "" }
        }
      },
      "items": {}
    }
  ]
}
